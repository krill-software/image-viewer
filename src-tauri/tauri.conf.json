{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Viewer",
  "version": "0.1.0",
  "identifier": "com.fippli.image-viewer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Image Viewer",
        "width": 1100,
        "height": 760,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A minimal image viewer for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to an image file to open"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Image viewer",
    "longDescription": "A minimal, single-window image viewer for Linux. Open one image, see it. Quiet by design.",
    "fileAssociations": [
      {
        "ext": ["png", "jpg", "jpeg", "webp", "gif", "avif", "svg", "bmp", "ico"],
        "name": "Image",
        "description": "Image file",
        "mimeType": "image/png;image/jpeg;image/webp;image/gif;image/avif;image/svg+xml;image/bmp;image/x-icon",
        "role": "Viewer"
      }
    ],
    "linux": {
      "deb": {
        "section": "graphics",
        "priority": "optional",
        "desktopTemplate": "main.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
